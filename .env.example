# Ollama service URL (use container name when running via Docker Compose)
OLLAMA_URL=http://ollama:11434

# HuggingFace Transformers model cache directory
TRANSFORMERS_CACHE=/root/.cache/huggingface

# Path for ChromaDB persistent storage
CHROMA_DB_PATH=/app/chroma_db

# Default Ollama model to use for analysis
DEFAULT_OLLAMA_MODEL=mistral

# Maximum word count for full document analysis
MAX_WORD_COUNT=50000

# Word count cap for perplexity scoring
PERPLEXITY_WORD_CAP=10000
